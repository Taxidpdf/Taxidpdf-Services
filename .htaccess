# ----------------------------------------------------------------------
# Force HTTPS and Canonical Domain Redirects
# ----------------------------------------------------------------------

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Redirect HTTP to HTTPS
    # This checks if HTTPS is off or if the server port is 80, and redirects permanently to HTTPS
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{SERVER_PORT} 80
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Redirect www.taxidpdf.com to taxidpdf.com (Canonicalization)
    # This ensures consistent cookies, security headers, and SEO ranking
    RewriteCond %{HTTP_HOST} ^www\.taxidpdf\.com$ [NC]
    RewriteRule ^(.*)$ https://taxidpdf.com/$1 [L,R=301]

    # 3. React SPA Fallback Routing
    # This ensures that deep links like /dashboard or /login are handled by React index.html
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.html [L]
</IfModule>
